      "tipo": "parear",
      "instrucao": "Conecte a forma verbal ao sujeito correspondente:",
      "pares": [
        ["לוֹמֵד", "הוּא / אַתָּה / אֲנִי (masc.)"],
        ["לוֹמֶדֶת", "הִיא / אַתְּ / אֲנִי (fem.)"],
