    {
      "id": "ex-01-parear-conjugacao",
      "tipo": "parear",
      "instrucao": "Conecte a forma verbal ao sujeito correspondente:",
      "pares": [
        ["לוֹמֵד", "הוּא / אַתָּה / אֲנִי (masc.)"],
        ["לוֹמֶדֶת", "הִיא / אַתְּ / אֲנִי (fem.)"],
        ["לוֹמְדִים", "הֵם / אַתֶּם / אֲנַחְנוּ (masc.)"],
        ["לוֹמְדוֹת", "הֵן / אַתֶּן / אֲנַחְנוּ (fem.)"]
      ]
    },
    {
      "id": "ex-02-parear-demonstrativos",
      "tipo": "parear",
      "instrucao": "זֶה, זֹאת ou אֵלֶּה? Conecte ao demonstrativo correto:",
      "pares": [
        ["מַחְשֵׁב", "זֶה"],
        ["עוּגָה", "זֹאת"],
        ["יַלְדָּה", "זֹאת"],
        ["בִּנְיָן", "זֶה"],
        ["סְפָרִים", "אֵלֶּה"]
      ]
    },
    {
      "id": "ex-03-parear-verbos",
      "tipo": "parear",
      "instrucao": "Conecte o verbo ao seu significado:",
      "pares": [
        ["כּוֹתֵב", "escreve"],
        ["קוֹרֵא", "lê"],
        ["מְדַבֵּר", "fala"],
        ["שׁוֹתֶה", "bebe"],
        ["אוֹהֵב", "ama / gosta"]
      ]
    },
    {
      "id": "ex-04-lacuna-pergunta",
      "tipo": "lacuna",
      "instrucao": "Escolha a palavra interrogativa correta:",
      "template": "___ אַתָּה הוֹלֵךְ?",
      "traducao": "___ você vai?",
      "opcoes": ["לְאָן", "מֵאַיִן", "מִי", "אֵיפֹה"],
      "resposta": "לְאָן"
    },
    {
      "id": "ex-05-lacuna-yesh-ain",
      "tipo": "lacuna",
      "instrucao": "Complete com יֵשׁ ou אֵין:",
      "template": "בַּגָּלִיל ___ הָרִים, אֲבָל בְּתֵל אָבִיב ___ הָרִים",
      "traducao": "Na Galileia há montanhas, mas em Tel Aviv não há montanhas",
      "opcoes": ["יֵשׁ ... אֵין", "אֵין ... יֵשׁ", "יֵשׁ ... יֵשׁ", "אֵין ... אֵין"],
      "resposta": "יֵשׁ ... אֵין"
    },
    {
      "id": "ex-06-montar-frase",
      "tipo": "montar_frase",
      "instrucao": "Monte a frase em hebraico:",
      "frase_pt": "Ele escreve uma carta para o amigo",
      "frase_heb": "הוּא כּוֹתֵב מִכְתָּב לַחָבֵר",
      "banco": [
        "הוּא", "כּוֹתֵב", "מִכְתָּב", "לַחָבֵר",
        "הִיא", "קוֹרֵאת", "לַחֲבֵרָה", "מְדַבֵּר"
      ]
    }
  ]
